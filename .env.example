# ─── AlphaBrain Environment Variables ───
# Copy this file to .env and fill in the values.

# JWT secret (min 32 characters, change for production!)
JWT_SECRET=change_me_in_production_min_32_chars

# Gemini API key for AI features (optional — app works without it)
GEMINI_API_KEY=

# CORS allowed origins (comma-separated, set to your frontend domain)
CORS_ORIGINS=http://localhost:3000

# Port overrides (optional)
FRONTEND_PORT=3000
BACKEND_PORT=8081
MONGO_PORT=27017

# Logging level (DEBUG, INFO, WARN, ERROR)
APP_LOG_LEVEL=INFO
